  {key:"focus",label:"Focus / topic",prompt:(r)=>`<div class="mode-badge">Focus / topic — identify the study</div><div class="clue-text">"${r.focus}"</div>`},
  {key:"authors",label:"Who wrote it?",prompt:(r)=>`<div class="mode-badge">Authors & year — who wrote this study?</div><div class="clue-text" style="font-style:italic">"${r.title}"</div>`},
  {key:"title",label:"Identify the title",prompt:(r)=>`<div class="mode-badge">Identify the title — which study matches this focus?</div><div class="clue-text">"${r.focus}"</div><div class="clue-label">Context hint:</div><div class="clue-text" style="font-size:13px;color:var(--text2)">${r.context.slice(0,120)}…</div>`}
];

let state={mode:0,queue:[],current:0,score:0,total:0,answered:false,showHint:false,opts:[],done:false};

function shuffle(a){let b=[...a];for(let i=b.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]]}return b}

function getWrongOpts(correct){
  return shuffle(RRLS.filter(r=>r.id!==correct.id)).slice(0,3);
}

function optLabel(rrl){
  const m=MODES[state.mode];
  if(m.key==="authors") return rrl.authors+" ("+rrl.year+")";
  if(m.key==="title") return rrl.title;
  return rrl.id+" — "+rrl.title.slice(0,48)+(rrl.title.length>48?"…":"");
}

function render(){
  const root=document.getElementById("quiz-root");
  if(state.done){
    const pct=Math.round((state.score/state.total)*100);
    const grade=pct>=90?"Excellent!":pct>=75?"Good job!":pct>=50?"Keep practicing!":"Review and retry!";
    const gradeColor=pct>=75?"var(--green-bg);color:var(--green-text);border:1px solid var(--green-border)":"pct>=50?\"var(--amber-bg);color:var(--amber-text);border:1px solid var(--amber-border)\":\"var(--red-bg);color:var(--red-text);border:1px solid var(--red-border)\"";
    root.innerHTML=`<div class="end-card">
      <div style="font-size:36px;margin-bottom:.5rem">${pct>=75?"🎉":pct>=50?"👍":"📖"}</div>
      <div class="end-score">${state.score}<span style="font-size:24px;color:var(--text2)">/${state.total}</span></div>
      <div style="display:inline-block;padding:4px 16px;border-radius:99px;font-size:13px;font-weight:600;margin:.5rem 0 1rem;background:${pct>=75?"var(--green-bg);color:var(--green-text)":pct>=50?"var(--amber-bg);color:var(--amber-text)":"var(--red-bg);color:var(--red-text)"}">${pct}% — ${grade}</div>
      <div class="end-label">You completed all ${state.total} questions in <strong>${MODES[state.mode].label}</strong> mode.</div>
      <button class="next-btn" onclick="restart()" style="margin:auto;display:block">Restart quiz</button>
    </div>`;
    return;
  }

  const rrl=state.queue[state.current];
  const opts=state.opts.length?state.opts:(state.opts=shuffle([rrl,...getWrongOpts(rrl)]));
  const prog=Math.round((state.current/state.queue.length)*100);
  const m=MODES[state.mode];
  const showHintBtn=m.key!=="authors"&&m.key!=="title";

  root.innerHTML=`
  <div class="top-bar">
    <div class="score-row">
      <span class="pill pill-correct">✓ ${state.score}</span>
      <span class="pill pill-wrong">✗ ${state.total-state.score}</span>
      <span class="pill pill-info">${state.current+1} / ${state.queue.length}</span>
    </div>
    <button class="restart-btn" onclick="restart()">↺ Restart</button>
  </div>
  <div class="mode-tabs">
    ${MODES.map((mo,i)=>`<button class="tab${state.mode===i?" active":""}" onclick="changeMode(${i})">${mo.label}</button>`).join("")}
  </div>
  <div class="progress-wrap"><div class="progress-bar" style="width:${prog}%"></div></div>
  <div class="card">
    ${m.prompt(rrl)}
    ${showHintBtn?`<button class="hint-btn" onclick="toggleHint()">💡 ${state.showHint?"Hide hint":"Show hint (author & year)"}</button>${state.showHint?`<div class="hint-reveal">Author(s): <strong>${rrl.authors}</strong> &nbsp;|&nbsp; Year: <strong>${rrl.year}</strong></div>`:""}`:``}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:1.25rem" id="opts-grid">
      ${opts.map((o,i)=>`<button class="opt" id="opt-${i}" onclick="choose(${i})">${optLabel(o)}</button>`).join("")}
    </div>
    <div id="feedback-area"></div>
    <div class="nav-row" id="nav-row" style="display:none">
      <button class="next-btn" onclick="next()">${state.current+1>=state.queue.length?"See results →":"Next →"}</button>
    </div>
  </div>`;
}

function toggleHint(){
  state.showHint=!state.showHint;
  render();
}

function changeMode(i){
  state.mode=i;
  state.queue=shuffle([...RRLS]);
  state.current=0;state.score=0;state.total=0;state.done=false;state.opts=[];state.showHint=false;
  render();
}

function choose(i){
  if(state.answered) return;
  state.answered=true;state.total++;
  const rrl=state.queue[state.current];
  const chosen=state.opts[i];
  const correct=chosen.id===rrl.id;
  if(correct) state.score++;
  state.opts.forEach((o,idx)=>{
    const btn=document.getElementById("opt-"+idx);
    if(!btn) return;
    btn.disabled=true;
    if(o.id===rrl.id) btn.className="opt "+(idx===i?"correct":"reveal");
    else if(idx===i) btn.className="opt wrong";
    else btn.style.opacity=".35";
  });
  document.getElementById("feedback-area").innerHTML=`
    <div class="feedback ${correct?"correct":"wrong"}">${correct?"✓ Correct!":"✗ Incorrect."} <span style="font-weight:normal">${rrl.id} — ${rrl.title}</span></div>
    <div class="detail-block">
      <strong>Authors:</strong> ${rrl.authors} (${rrl.year})<br>
      <strong>Focus:</strong> ${rrl.focus}<br>
      <strong>Key result:</strong> ${rrl.result}
    </div>`;
  document.getElementById("nav-row").style.display="flex";
}

function next(){
  state.current++;state.answered=false;state.showHint=false;state.opts=[];
  if(state.current>=state.queue.length) state.done=true;
  render();
}

function restart(){
  Object.assign(state,{queue:shuffle([...RRLS]),current:0,score:0,total:0,done:false,answered:false,showHint:false,opts:[]});
  render();
}

restart();
</script>
</body>
</html>
